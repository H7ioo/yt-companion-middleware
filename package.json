{
  "name": "yt-companion-middleware",
  "version": "2.0.0",
  "description": "Middleware between Bitfocus Companion and the YouTube Live Streaming API",
  "type": "module",
  "private": true,
  "main": "electron/main.mjs",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shared",
    "packages/server",
    "packages/web"
  ],
  "allowScripts": {
    "esbuild@0.25.12": true
  },
  "scripts": {
    "dev": "npm run dev -w @app/server",
    "build:shared": "npm run build -w @app/shared",
    "build:server": "npm run build -w @app/server",
    "build:web": "npm run build:shared && npm run build -w @app/web",
    "build": "tsc -b tsconfig.json",
    "build:all": "npm run build:web && npm run build:server",
    "start": "npm run start -w @app/server",
    "test": "npm run build:shared && vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run build:shared && npm run typecheck -w @app/server",
    "typecheck:electron": "tsc --noEmit -p tsconfig.electron.json",
    "desktop:icons": "node electron/scripts/make-icons.mjs",
    "desktop:dev": "npm run build:all && electron .",
    "desktop:pack": "npm run desktop:icons && npm run build:all && electron-builder --dir",
    "desktop:build": "npm run typecheck:electron && npm run desktop:icons && npm run build:all && electron-builder --win --publish never",
    "companion:install": "npm --prefix companion-module install",
    "companion:check": "npm --prefix companion-module run check",
    "companion:test": "vitest run companion-module",
    "companion:bump": "node companion-module/scripts/bump-version.mjs",
    "companion:package": "npm --prefix companion-module install && npm --prefix companion-module run package"
  },
  "build": {
    "appId": "com.h7ioo.ytcompanion",
    "productName": "YT Companion",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "packages/server/dist/**/*",
      "packages/server/public/**/*",
      "packages/web/dist/**/*",
      "electron/main.mjs",
      "electron/assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/@napi-rs/canvas*/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "YT Companion"
    },
    "portable": {
      "artifactName": "YT-Companion-${version}-portable.exe"
    }
  },
  "dependencies": {
    "@app/server": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
