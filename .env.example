# YouTube OAuth 2.0 credentials (Google Cloud Console -> OAuth client)
YT_CLIENT_ID=your-client-id.apps.googleusercontent.com
YT_CLIENT_SECRET=your-client-secret

# Refresh token obtained once via the OAuth consent flow.
# Stored server-side only; never exposed to Companion or any client.
YT_REFRESH_TOKEN=your-refresh-token

# HTTP server
PORT=8080

# Directory for the JSON store (mounted as a Docker volume in production)
DATA_DIR=./data

# Seconds between background state-cache refreshes
REFRESH_INTERVAL_SECONDS=60

# Consecutive refresh failures before health escalates ok -> degraded -> auth_error
HEALTH_FAILURE_THRESHOLD=3

# Region (ISO 3166-1 alpha-2) used to fetch the assignable video-category list
YT_REGION_CODE=US

# Daily YouTube Data API quota budget in cost-weighted units (reads=1, writes=50).
# Default project quota is 10,000/day; surfaced on the dashboard + /api/feedback/health.
YT_QUOTA_LIMIT=10000
